# Server port
PORT=4000

# development | production | test
NODE_ENV=development

# Required for /api/chat and /api/report (Lovable AI Gateway key).
LOVABLE_API_KEY=

# Model forwarded to the Lovable AI Gateway.
# google/gemini-3-flash-preview was invalid; correct default below.
# Override if the gateway supports a newer/different model.
AI_MODEL=google/gemini-2.0-flash

# Max AI requests per IP per minute (default: 10).
AI_RATE_LIMIT_MAX=10

# Comma-separated list of allowed CORS origins, or "*" for any origin.
CORS_ORIGIN=*

# Absolute or relative path to the built client SPA (client/dist).
# Defaults to ../client/dist relative to the server package if unset.
# CLIENT_DIST_PATH=

# TTL (ms) for the in-memory Yahoo Finance market-data cache.
MARKET_DATA_CACHE_TTL_MS=300000

# debug | info | warn | error
LOG_LEVEL=info
