{
  "name": "vidura-server",
  "private": true,
  "type": "commonjs",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit -p tsconfig.json",
    "start": "exec tsx src/server.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.48",
    "ai": "^6.0.197",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.6.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "node-cache": "^5.1.2",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.16.5",
    "typescript": "^5.8.3",
    "@eslint/js": "^9.0.0",
    "globals": "^15.0.0",
    "typescript-eslint": "^8.0.0",
    "eslint": "^9.0.0"
  },
  "description": "Vidura Express API server. Runtime: tsx (intentional \u2014 transpiles TypeScript on the fly at startup; tsx is in dependencies so it is available in production). Build script runs tsc --noEmit (type-check only \u2014 no compiled JS artifact). Entry point: src/server.ts"
}
